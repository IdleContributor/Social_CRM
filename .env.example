# ── X (Twitter) ───────────────────────────────────────────────────────
# From developer.twitter.com → Your App → Keys and Tokens → OAuth 2.0
# Callback URL to register: https://your-backend.com/x/callback
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
X_REDIRECT_URI=http://localhost:5000/x/callback

# ── Instagram ─────────────────────────────────────────────────────────
# Uses the same Facebook App (APP_ID / APP_SECRET) — no separate credentials needed.
# Required permissions on your Meta App:
#   instagram_basic, instagram_content_publish, pages_show_list, pages_read_engagement
# Callback URL to register in Meta App: https://your-backend.com/instagram/callback
IG_REDIRECT_URI=http://localhost:5000/instagram/callback

# ── Facebook ──────────────────────────────────────────────────────────
APP_ID=your_facebook_app_id
APP_SECRET=your_facebook_app_secret

# ── Threads ───────────────────────────────────────────────────────────
THREADS_APP_ID=your_threads_app_id
THREADS_APP_SECRET=your_threads_app_secret
THREADS_REDIRECT_URI=https://social.simar.dev

# Public URL for Threads image hosting (must be reachable by Meta servers)
PUBLIC_HOST=

# ── LinkedIn ──────────────────────────────────────────────────────────
LI_CLIENT_ID=your_linkedin_client_id
LI_CLIENT_SECRET=your_linkedin_client_secret
# LinkedIn callback hits the backend directly to avoid code expiry
LI_REDIRECT_URI=
# ── URLs ──────────────────────────────────────────────────────────────
FRONTEND_URL=
BACKEND_URL=

# ── Server ────────────────────────────────────────────────────────────
PORT=
